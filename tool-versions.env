# Pinned tool versions for Oxen development.
#
# This file is the single source of truth read by:
#   - scripts/install-pre-reqs.sh
#   - .github/workflows/ci_lint.yml
#   - .pre-commit-config.yaml (local hooks)
#
# Format: KEY=VALUE (no spaces around '=', no quoting needed).
# Lines starting with '#' are comments.

# Cargo-installable tools
BACON_VERSION=3.22.0
CARGO_MACHETE_VERSION=0.9.1
CARGO_LLVM_COV_VERSION=0.8.4
CARGO_SORT_VERSION=2.1.0
CARGO_NEXTEST_VERSION=0.9.114

# Shell tools
SHELLCHECK_VERSION=0.11.0

# Python tools (installed via uvx / uv tool)
RUFF_VERSION=0.15.2
